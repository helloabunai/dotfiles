# General
alias ll='ls -l'
alias la='ls -la'
alias l='ls -CF'

# stufffffff
alias hconf='nano ~/.config/hypr/hyprland.lua'
alias hlogout="hyprctl dispatch 'hl.dsp.exit()'"
alias refresh='hyprctl reload'
alias lsd='eza --icons'
alias pacup='sudo pacman -Rns $(pacman -Qdtq)'
alias grep='grep --color=auto'
alias pool='clear && asciiquarium'
alias f='clear && myfetch -i e -f -c 16 -C "  "'
alias bye='sudo shutdown -h now'
alias loop='sudo reboot'
alias h='dbus-launch Hyprland'
alias fonts='fc-list -f "%{family}\n"'
alias tasks='btm'
alias Docs="cd ~/Documents && nvim"
alias Settings="cd ~/.config/hypr && nvim"
alias spot="ncspot"
alias untar="tar -xf"
alias n="nvim"
alias pipes="pipes.sh -p 4 -t 5 -r"
alias gameflag='nvim ~/scripts/game_envs.json'
alias reshade='RESHADE_ADDON_SUPPORT=1 ~/scripts/reshade-linux.sh'

# servers
alias cottus="export TERM=xterm && ssh cottus"
alias tanaris="export TERM=xterm && ssh tanaris"
alias sundeck="/usr/bin/zsh /home/alastairm/scripts/set_stream_display.sh deck"
alias sunshield="/usr/bin/zsh /home/alastairm/scripts/set_stream_display.sh shield"
alias sunmac="/usr/bin/zsh /home/alastairm/scripts/set_stream_display.sh mac"
alias sunmachdr="/usr/bin/zsh /home/alastairm/scripts/set_stream_display.sh machdr"
alias streamdisplay='cat ~/.config/scripts/streamdisplay'
alias controller="cd /home/alastairm/repos/xpadneo && sudo ./update.sh"
alias systemupdate="hyde-shell systemupdate up"
alias removetv="hyprctl eval 'hl.monitor({ output = \"HDMI-A-1\", disabled = true })'"
alias removedeck="hyprctl eval 'hl.monitor({ output = \"HDMI-A-2\", disabled = true })'"
alias fixgit="ssh-add ~/.ssh/github"
alias fixwaybar="pkill kded6"
alias gs="git status"
alias gemini="agy"
